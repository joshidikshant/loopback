{
  "name": "loopback-mcp-server",
  "version": "0.2.0",
  "description": "Loopback — a project-tagged feedback bus for coding agents (Claude Code, Codex, Gemini CLI) over MCP. Capture UI/backend/usage/UX feedback once; let any agent claim, fix, and write the change back.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "loopback-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node dist/smoke-test.js",
    "e2e": "node scripts/e2e.mjs",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshidikshant/loopback.git"
  },
  "homepage": "https://github.com/joshidikshant/loopback#readme",
  "bugs": {
    "url": "https://github.com/joshidikshant/loopback/issues"
  },
  "engines": {
    "node": ">=22.13"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "feedback",
    "coding-agents",
    "claude-code",
    "codex",
    "gemini-cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
